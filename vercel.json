{
  "buildCommand": "npm run build:all",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/operator",
      "destination": "/operator/index.html"
    },
    {
      "source": "/operator/ced",
      "destination": "/operator/ced/index.html"
    },
    {
      "source": "/operator/ced/(.*)",
      "destination": "/operator/ced/index.html"
    },
    {
      "source": "/operator/cdd",
      "destination": "/operator/cdd/index.html"
    },
    {
      "source": "/operator/cdd/(.*)",
      "destination": "/operator/cdd/index.html"
    },
    {
      "source": "/tools/ced",
      "destination": "/tools/ced/index.html"
    },
    {
      "source": "/tools/ced/(.*)",
      "destination": "/tools/ced/index.html"
    },
    {
      "source": "/tools/gtm-coverage",
      "destination": "/tools/gtm-coverage/index.html"
    },
    {
      "source": "/tools/gtm-coverage/(.*)",
      "destination": "/tools/gtm-coverage/index.html"
    },
    {
      "source": "/tools/win-loss",
      "destination": "/tools/win-loss/index.html"
    },
    {
      "source": "/tools/win-loss/(.*)",
      "destination": "/tools/win-loss/index.html"
    },
    {
      "source": "/tools/commercial-scorecard",
      "destination": "/tools/commercial-scorecard/index.html"
    },
    {
      "source": "/tools/commercial-scorecard/(.*)",
      "destination": "/tools/commercial-scorecard/index.html"
    },
    {
      "source": "/tools/churn-scorecard",
      "destination": "/tools/churn-scorecard/index.html"
    },
    {
      "source": "/tools/churn-scorecard/(.*)",
      "destination": "/tools/churn-scorecard/index.html"
    },
    {
      "source": "/tools/gtm-org",
      "destination": "/tools/gtm-org/index.html"
    },
    {
      "source": "/tools/gtm-org/(.*)",
      "destination": "/tools/gtm-org/index.html"
    },
    {
      "source": "/tools/priming-window",
      "destination": "/tools/priming-window/index.html"
    },
    {
      "source": "/tools/priming-window/(.*)",
      "destination": "/tools/priming-window/index.html"
    },
    {
      "source": "/tools/gtm-teardown",
      "destination": "/tools/gtm-teardown/index.html"
    },
    {
      "source": "/tools/gtm-teardown/(.*)",
      "destination": "/tools/gtm-teardown/index.html"
    },
    {
      "source": "/tools/deal-memo",
      "destination": "/tools/deal-memo/index.html"
    },
    {
      "source": "/tools/deal-memo/(.*)",
      "destination": "/tools/deal-memo/index.html"
    },
    {
      "source": "/writing/:path*",
      "destination": "/writing/:path*/index.html"
    }
  ]
}
